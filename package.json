    "@x402/evm": "^2.10.0",
    "next": "^15.3.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "viem": "^2.48.1",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "eslint": "9.25.1",
    "eslint-config-next": "^15.3.8",
    "tsx": "^4.21.0",
    "typescript": "5.8.3"
  }
