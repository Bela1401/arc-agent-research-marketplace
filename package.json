{
  "name": "arc-agent-research-marketplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "circle:entity-secret:generate": "tsx scripts/setup-entity-secret.ts generate",
