    "arc:bootstrap": "tsx --env-file=.env.local scripts/bootstrap-wallets.ts",
    "arc:register-agents": "tsx --env-file=.env.local scripts/register-marketplace-agents.ts",
    "arc:run-job": "tsx --env-file=.env.local scripts/run-marketplace-job.ts"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.3.0",
